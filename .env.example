# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Configurações da aplicação
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_CPF_ENCRYPTION_KEY=sua-chave-segura-aqui-minimo-32-caracteres

VITE_APP_NAME=QuermesseOn!
VITE_APP_VERSION=1.0.0

# URL da aplicação (usado para gerar QR Codes com URL completa)
#
# IMPORTANTE: Para QR Codes funcionarem em iPhone/Android, NÃO use localhost!
#
# Opções:
# 1. 'auto' - Detecta automaticamente o IP da rede (RECOMENDADO para desenvolvimento)
#    VITE_APP_URL=auto
#
# 2. IP específico da rede - Use o IP mostrado no terminal quando rodar 'npm run dev'
#    Exemplo: VITE_APP_URL=http://192.168.1.100:3000
#
# 3. Domínio em produção
#    Exemplo: VITE_APP_URL=https://quermesse.com
#
# ⚠️ EVITE usar localhost - QR Codes não funcionarão em outros dispositivos!
#
# Em desenvolvimento (RECOMENDADO):
VITE_APP_URL=auto
#
# Em produção:
# VITE_APP_URL=https://seu-dominio.com

# Limites
VITE_MAX_CART_ITEMS=50
VITE_MAX_TRANSFER_AMOUNT=1000
VITE_MIN_RECHARGE_AMOUNT=10

# Features (opcional)
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false

# ============================================================================
# PIX RECHARGE - Woovi Integration (0,99% fee)
# ============================================================================
# Para ativar recarga via PIX:
# 1. Crie conta em https://woovi.com
# 2. Obtenha suas credenciais no painel Woovi
# 3. Configure as variáveis abaixo
# 4. Ative a feature em src/lib/features.js (PIX_RECHARGE: true)
#
# IMPORTANTE: Estas variáveis também devem ser configuradas no Supabase:
# - Dashboard > Settings > Edge Functions > Environment Variables
#
# Variáveis necessárias:
VITE_WOOVI_APP_ID=your_woovi_app_id_here
# WOOVI_API_KEY=your_woovi_api_key_here (apenas no Supabase - NÃO expor no frontend)
# WOOVI_WEBHOOK_SECRET=your_webhook_secret_here (apenas no Supabase)
#
# Configuração do Webhook Woovi:
# URL: https://your-project.supabase.co/functions/v1/pix-webhook
# Eventos: CHARGE_COMPLETED
#
# Para desativar PIX:
# - Mude PIX_RECHARGE para false em src/lib/features.js
# - Ou comente/remova a linha VITE_WOOVI_APP_ID
# ============================================================================